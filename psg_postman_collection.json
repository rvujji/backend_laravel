        {
          "listen": "test",

          "script": {

            "type": "text/javascript",

            "exec": [

              "pm.test('Admin enrollments list success', function () {",
              "    pm.response.to.have.status(200);",
              "});",

              "",

              "const response = pm.response.json();",

              "",

              "pm.test('Response contains paginated data', function () {",
              "    pm.expect(response).to.have.property('data');",
              "    pm.expect(response.data).to.have.property('data');",
              "    pm.expect(response.data.data).to.be.an('array');",
              "});",

              "",

              "if (response.data.data.length > 0) {",

              "    pm.test('Enrollment fields exist', function () {",

              "        const item = response.data.data[0];",

              "        pm.expect(item).to.have.property('id');",
              "        pm.expect(item).to.have.property('student_id');",
              "        pm.expect(item).to.have.property('workshop_id');",
              "        pm.expect(item).to.have.property('status');",

              "    });",

              "}"
            ]
          }
        }
